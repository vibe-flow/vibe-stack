# Database (local-services uses local-postgres on port 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"

# Redis (local-services uses local-redis on port 6379)
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-here"
JWT_REFRESH_EXPIRES_IN="7d"

# LiteLLM (local-services provides LiteLLM on port 4001)
# LITELLM_BASE_URL="http://localhost:4001"
# LITELLM_MASTER_KEY="sk-local-master-key"

# LLM Provider API Keys (optional — set in local-services/.env instead)
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OPENAI_API_KEY="sk-xxx"

# Queue (optional, set to true to enable BullMQ)
QUEUE_ENABLED="false"

# Ports
FRONTEND_PORT="5173"
BACKEND_PORT="3000"

# S3 / Minio (local-services provides Minio on port 9000)
# S3_ENDPOINT="http://localhost:9000"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_BUCKET="myproject"

# Mail (local-services provides Mailpit on port 1025)
MAIL_HOST="localhost"
MAIL_PORT="1025"
MAIL_FROM="noreply@myproject.localhost"

# Frontend URL (for magic link emails)
FRONTEND_URL="http://localhost:5173"

# Auth config overrides (optional — defaults in apps/api/src/config/auth.config.ts)
# AUTH_REGISTRATION_MODE="open"
# AUTH_MAGIC_LINK_TTL="15"
# AUTH_DEV_LOGIN="true"

# Frontend dev mode
VITE_DEV_LOGIN="true"
